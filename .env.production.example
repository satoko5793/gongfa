DATABASE_URL=postgres://gongfa:replace-with-password@replace-with-db-host:5432/gongfa
JWT_SECRET=replace-with-a-long-random-secret
PORT=8090

# Leave USE_FILE_STORE unset in production.
# USE_FILE_STORE=1

# Optional. Keep empty if helper is not exposed online.
HELPER_ORIGIN=
HELPER_BRIDGE_ENABLED=0
HELPER_BRIDGE_MODE=off
HELPER_PUBLIC_BASE=/xyzw-helper
HELPER_API_BASE=/api
HELPER_SCAN_BIND_ENABLED=0
HELPER_TEAM_SNAPSHOT_ENABLED=0
HELPER_TEAM_SWITCH_ENABLED=0
HELPER_TEAM_RESTORE_ENABLED=0
HELPER_ALLOWED_USER_IDS=
HELPER_ALLOWED_GAME_ROLE_IDS=
