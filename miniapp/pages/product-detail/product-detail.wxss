.detail-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(248, 241, 230, 0.96) 100%);
}

.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.detail-price {
  min-width: 120rpx;
  text-align: right;
  font-size: 42rpx;
  font-weight: 800;
  color: #c4552d;
}

.detail-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.detail-badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f2e7d8;
  color: #5b3f24;
  font-size: 24rpx;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.detail-metric {
  padding: 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1px solid rgba(118, 93, 67, 0.12);
}

.metric-label {
  font-size: 24rpx;
  color: #6a6157;
}

.metric-value {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #201b16;
}

.detail-line {
  margin-top: 16rpx;
}

.line-value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #201b16;
}

.stack-item {
  margin-top: 12rpx;
}

.action-card {
  position: sticky;
  bottom: 24rpx;
}

.secondary-action {
  margin-top: 16rpx;
}
