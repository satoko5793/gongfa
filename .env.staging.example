NODE_ENV=production
PORT=8090
USE_FILE_STORE=1
JWT_SECRET=replace-with-a-different-random-secret

# Optional. Keep empty if helper is not exposed online.
HELPER_ORIGIN=
HELPER_BRIDGE_ENABLED=1
HELPER_BRIDGE_MODE=staging
HELPER_PUBLIC_BASE=/xyzw-helper
HELPER_API_BASE=/api
HELPER_SCAN_BIND_ENABLED=1
HELPER_TEAM_SNAPSHOT_ENABLED=1
HELPER_TEAM_SWITCH_ENABLED=1
HELPER_TEAM_RESTORE_ENABLED=0
