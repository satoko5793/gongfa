@@ -0,0 +1,95 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
+GO_BIN="/data/home/xyq/gongfa/功法/.tools/go-linux/bin/go"
+APP_BIN="$ROOT_DIR/bin/xyzw-linux"
+LOG_DIR="$ROOT_DIR/logs"
+PID_FILE="$LOG_DIR/xyzw.pid"
+LOG_FILE="$LOG_DIR/xyzw.log"
+
+mkdir -p "$LOG_DIR" "$ROOT_DIR/bin"
+
+build_if_needed() {
+  if [[ ! -x "$APP_BIN" ]]; then
+    "$GO_BIN" build -o "$APP_BIN" ./cmd/xyzw
+  fi
+}
+
+is_running() {
+  if [[ -f "$PID_FILE" ]]; then
+    local pid
+    pid="$(cat "$PID_FILE" 2>/dev/null || true)"
+    if [[ -n "${pid:-}" ]] && kill -0 "$pid" 2>/dev/null; then
+      return 0
+    fi
+  fi
+  local found
+  found="$(ps -eo pid=,args= | rg '(^| )(\./)?bin/xyzw-linux($| )' | awk 'NR==1{print $1}' || true)"
+  if [[ -n "${found:-}" ]]; then
+    echo "$found" > "$PID_FILE"
+    return 0
+  fi
+  return 1
+}
+
+cmd_start() {
+  if is_running; then
+    echo "already running: pid $(cat "$PID_FILE")"
+    return 0
+  fi
+  build_if_needed
+  cd "$ROOT_DIR"
+  setsid env XY_SKIP_UPDATE_CHECK=1 XY_CAPTURE_HOST="*" XY_PASSIVE_CAPTURE=1 "$APP_BIN" >"$LOG_FILE" 2>&1 < /dev/null &
+  echo $! > "$PID_FILE"
+  sleep 1
+  if is_running; then
+    echo "started: pid $(cat "$PID_FILE")"
+  else
+    echo "failed to start, check log: $LOG_FILE"
+    exit 1
+  fi
+}
+
+cmd_stop() {
+  if ! is_running; then
+    echo "not running"
+    rm -f "$PID_FILE"
+    return 0
+  fi
+  local pid
+  pid="$(cat "$PID_FILE")"
+  kill "$pid" || true
+  sleep 1
+  if kill -0 "$pid" 2>/dev/null; then
+    kill -9 "$pid" || true
+  fi
+  rm -f "$PID_FILE"
+  echo "stopped"
+}
+
+cmd_status() {
+  if is_running; then
+    echo "running: pid $(cat "$PID_FILE")"
+  else
+    echo "not running"
+  fi
+  ss -ltnp | rg ':12311|:12582' || true
+}
+
+cmd_logs() {
+  tail -n 80 "$LOG_FILE" 2>/dev/null || true
+}
+
+ACTION="${1:-status}"
+case "$ACTION" in
+  start) cmd_start ;;
+  stop) cmd_stop ;;
+  restart) cmd_stop; cmd_start ;;
+  status) cmd_status ;;
+  logs) cmd_logs ;;
+  *)
+    echo "usage: $0 {start|stop|restart|status|logs}"
+    exit 1
+    ;;
+esac
