@@ -0,0 +1,36 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+if [[ "${1:-}" == "" ]]; then
+  echo "usage: $0 <jsonl-file>"
+  exit 1
+fi
+
+FILE="$1"
+if [[ ! -f "$FILE" ]]; then
+  echo "file not found: $FILE"
+  exit 1
+fi
+
+echo "file: $FILE"
+echo "total lines:"
+wc -l "$FILE"
+
+echo
+echo "top hosts:"
+rg -o '"host":"[^"]*"' "$FILE" | sed 's/"host":"//;s/"$//' | sort | uniq -c | sort -nr | head -n 20
+
+echo
+echo "top paths:"
+rg -o '"path":"[^"]*"' "$FILE" | sed 's/"path":"//;s/"$//' | sort | uniq -c | sort -nr | head -n 20
+
+echo
+echo "top host+path:"
+awk '
+  match($0, /"host":"[^"]*"/, h) && match($0, /"path":"[^"]*"/, p) {
+    host=h[0]; path=p[0];
+    gsub(/"host":"|"/, "", host);
+    gsub(/"path":"|"/, "", path);
+    print host " " path;
+  }
+' "$FILE" | sort | uniq -c | sort -nr | head -n 30
