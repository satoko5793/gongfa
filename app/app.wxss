page {
  background: #f6f1e7;
  color: #201b16;
  font-family: sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
}

.has-floating-tab {
  padding-bottom: 188rpx;
}

.section {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(43, 32, 20, 0.08);
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.muted {
  color: #6a6157;
}

.primary-btn {
  background: #c4552d;
  color: #fff;
  border-radius: 999rpx;
}

.ghost-btn {
  background: #f2e7d8;
  color: #5b3f24;
  border-radius: 999rpx;
}

.field {
  margin-top: 16rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #6a6157;
  margin-bottom: 8rpx;
}

.field-input {
  width: 100%;
  min-height: 84rpx;
  border-radius: 18rpx;
  background: #fff;
  border: 1px solid rgba(118, 93, 67, 0.18);
  padding: 0 24rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.notice {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #fff7ef;
  color: #8a4f18;
}

.stack-item {
  padding: 16rpx 0;
  border-bottom: 1px solid rgba(118, 93, 67, 0.12);
}

.stack-item:last-child {
  border-bottom: none;
}

.quota-value {
  font-size: 52rpx;
  font-weight: 700;
  color: #c4552d;
}

.floating-tab-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 28rpx;
  z-index: 30;
  display: flex;
  gap: 14rpx;
  padding: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 249, 242, 0.94);
  border: 1px solid rgba(118, 93, 67, 0.12);
  box-shadow: 0 24rpx 56rpx rgba(79, 54, 31, 0.16);
  backdrop-filter: blur(20rpx);
}

.floating-tab-item {
  flex: 1;
  min-height: 92rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border-radius: 999rpx;
  color: #7b6855;
}

.floating-tab-item.active {
  background: linear-gradient(135deg, #c4552d 0%, #df7c46 100%);
  color: #fff7f1;
  box-shadow: 0 14rpx 28rpx rgba(196, 85, 45, 0.22);
}

.floating-tab-icon {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}

.floating-tab-label {
  font-size: 22rpx;
  line-height: 1.1;
}
